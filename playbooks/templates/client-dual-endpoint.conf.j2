# client wireguard config - dual-endpoint method
# jinja2 template for ansible playbooks

[Interface]
PrivateKey = {{ client_private_key }}
Address = {{ client_address }}
DNS = {{ pihole_ip }}

[Peer]
PublicKey = {{ server_a_public_key }}
AllowedIPs = 0.0.0.0/0
Endpoint = {{ wireguard_domain_a }}:51820
PersistentKeepalive = 25

[Peer]
PublicKey = {{ server_b_public_key }}
AllowedIPs = 0.0.0.0/0
Endpoint = {{ wireguard_domain_b }}:51820
PersistentKeepalive = 25
